# OpenPost Configuration

# Server Configuration
OPENPOST_PORT=8080
OPENPOST_DB_PATH=file:openpost.db?cache=shared&mode=rwc
OPENPOST_FRONTEND_URL=http://localhost:8080

# Authentication Secrets (GENERATE NEW ONES FOR PRODUCTION)
JWT_SECRET=generate_a_secure_random_string_here
ENCRYPTION_KEY=generate_a_secure_random_string_here

# Twitter/X OAuth (Get from https://developer.twitter.com/en/portal/dashboard)
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here

# Mastodon OAuth (Create app on each instance's Settings > Development)
# Each server needs its own client_id/secret since Mastodon apps are per-instance.
# MASTODON_SERVERS is a JSON array of server configs.
MASTODON_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
MASTODON_SERVERS='[
  {"name":"Personal","client_id":"your_client_id","client_secret":"your_client_secret","instance_url":"https://mastodon.social"}
]'
# Multiple servers example:
# MASTODON_SERVERS='[
#   {"name":"Personal","client_id":"abc","client_secret":"xyz","instance_url":"https://mastodon.social"},
#   {"name":"Work","client_id":"def","client_secret":"uvw","instance_url":"https://fosstodon.org"}
# ]'