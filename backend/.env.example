# OpenPost Configuration

# Server Configuration
OPENPOST_PORT=8080
OPENPOST_DB_PATH=file:openpost.db?cache=shared&mode=rwc
OPENPOST_FRONTEND_URL=http://localhost:8080

# Authentication Secrets (GENERATE NEW ONES FOR PRODUCTION)
JWT_SECRET=generate_a_secure_random_string_here
ENCRYPTION_KEY=generate_a_secure_random_string_here

# Twitter/X OAuth (Get from https://developer.twitter.com/en/portal/dashboard)
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here

# Mastodon OAuth (Create app on your instance's Settings > Development)
MASTODON_CLIENT_ID=your_mastodon_client_id_here
MASTODON_CLIENT_SECRET=your_mastodon_client_secret_here
# For local development, use oob (displays code in browser for manual entry)
MASTODON_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob