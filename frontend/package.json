{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:capacitor": "VITE_APP_MODE=capacitor vite build && npx cap sync android",
		"preview": "vite preview",
		"generate:i18n": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"generate:artifacts": "bun run generate:i18n && bun run generate:types",
		"check:types": "openapi-typescript openapi.json -o src/lib/api/types.d.ts --check",
		"prepare": "svelte-kit sync || echo ''",
		"check": "bun run generate:i18n && bun run check:types && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"generate:types": "openapi-typescript openapi.json -o src/lib/api/types.d.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@fontsource-variable/inter": "^5.2.8",
		"@inlang/paraglide-js": "^2.10.0",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"openapi-typescript": "^7.13.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"remixicon-svelte": "^0.0.5",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@capacitor/android": "^8.3.0",
		"@capacitor/app": "^8.1.0",
		"@capacitor/cli": "^8.3.0",
		"@capacitor/core": "^8.3.0",
		"@capacitor/splash-screen": "^8.0.1",
		"@capacitor/status-bar": "^8.0.2",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"lucide-svelte": "^0.577.0",
		"mode-watcher": "^1.1.0",
		"openapi-fetch": "^0.17.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2"
	}
}
